# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BookQuest

# Database (Neon recommended for Vercel)
DATABASE_URL=postgresql://user:password@localhost:5432/bookquest

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhooks → Configure → Webhooks → Signing secret
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Paystack (Nigeria / NGN) — Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...

# Admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Optional: durable file storage on Vercel (Blob/S3) — local dev uses ./storage/private
STORAGE_PROVIDER=local
